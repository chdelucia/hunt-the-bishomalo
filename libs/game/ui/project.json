{
  "name": "game-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/game/ui/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["scope:game", "type:ui"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/game/ui/jest.config.ts",
        "tsConfig": "libs/game/ui/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/game/ui/.storybook",
        "browserTarget": "game-ui:build-storybook",
        "compodoc": false,
        "assets": [
          {
            "glob": "**/*",
            "input": "public",
            "output": "/"
          }
        ]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/game-ui",
        "configDir": "libs/game/ui/.storybook",
        "browserTarget": "game-ui:build-storybook",
        "compodoc": false,
        "assets": [
          {
            "glob": "**/*",
            "input": "public",
            "output": "/"
          }
        ]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/game/ui/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "game-ui:build-storybook",
        "staticFilePath": "dist/storybook/game-ui",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "game-ui:build-storybook:ci"
        }
      }
    }
  }
}
